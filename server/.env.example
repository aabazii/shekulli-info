# Shekulli.info — Facebook Graph API credentials
# Copy this file to .env and fill in your values.
#
# HOW TO GET THESE (free, ~5 minutes):
# 1. Go to https://developers.facebook.com/apps/
# 2. Click "Create App" → choose "Business" type → give it any name
# 3. Once created, go to Settings → Basic
# 4. Copy "App ID" and "App Secret" below
# 5. Save .env, then run: node index.js
#
# The App Access Token is fetched automatically — you don't need to generate it.

FB_APP_ID=YOUR_APP_ID
FB_APP_SECRET=YOUR_APP_SECRET
