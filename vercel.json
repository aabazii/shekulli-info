{
  "framework": null,
  "buildCommand": null,
  "outputDirectory": ".",
  "installCommand": "npm install",
  "cleanUrls": true,
  "functions": {
    "api/admin/upload.js": { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/api/articles",             "destination": "/api/articles" },
    { "source": "/api/health",               "destination": "/api/health" },
    { "source": "/api/admin/import",         "destination": "/api/admin/import" },
    { "source": "/api/admin/fix-timestamps", "destination": "/api/admin/fix-timestamps" },
    { "source": "/api/admin/delete",         "destination": "/api/admin/delete" },
    { "source": "/api/admin/upload",         "destination": "/api/admin/upload" },
    { "source": "/api/admin/clear",          "destination": "/api/admin/clear" },
    { "source": "/api/fixtures",             "destination": "/api/fixtures" }
  ]
}
